generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admin_users {
  admin_id      Int         @id @default(autoincrement())
  username      String      @unique @db.VarChar(100)
  email         String      @unique @db.VarChar(255)
  password_hash String      @db.VarChar(255)
  role          admin_role? @default(admin)
  is_active     Boolean?    @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
}

model households {
  household_id    Int               @id @default(autoincrement())
  ward_id         Int
  household_name  String            @db.VarChar(200)
  address_line1   String            @db.VarChar(255)
  address_line2   String?           @db.VarChar(255)
  city            String            @db.VarChar(100)
  state           String            @db.VarChar(100)
  postal_code     String?           @db.VarChar(20)
  contact_phone   String            @db.VarChar(20)
  contact_email   String?           @db.VarChar(255)
  latitude        Decimal?          @db.Decimal(10, 8)
  longitude       Decimal?          @db.Decimal(11, 8)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?         @db.Timestamp(6)
  wards           wards             @relation(fields: [ward_id], references: [ward_id], onDelete: NoAction, onUpdate: NoAction)
  pickup_requests pickup_requests[]
  violations      violations[]

  @@index([contact_phone], map: "idx_households_contact_phone")
  @@index([is_active], map: "idx_households_is_active")
  @@index([ward_id], map: "idx_households_ward_id")
}

model pickup_assignments {
  assignment_id     Int             @id @default(autoincrement())
  pickup_request_id Int
  worker_id         Int
  assigned_at       DateTime?       @default(now()) @db.Timestamp(6)
  completed_at      DateTime?       @db.Timestamp(6)
  is_active         Boolean?        @default(true)
  notes             String?
  pickup_requests   pickup_requests @relation(fields: [pickup_request_id], references: [pickup_request_id], onDelete: NoAction, onUpdate: NoAction)
  workers           workers         @relation(fields: [worker_id], references: [worker_id], onDelete: NoAction, onUpdate: NoAction)
}

model pickup_request_waste_types {
  pickup_request_id Int
  waste_type_id     Int
  quantity_kg       Decimal?        @db.Decimal(8, 2)
  created_at        DateTime?       @default(now()) @db.Timestamp(6)
  pickup_requests   pickup_requests @relation(fields: [pickup_request_id], references: [pickup_request_id], onDelete: Cascade, onUpdate: NoAction)
  waste_types       waste_types     @relation(fields: [waste_type_id], references: [waste_type_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([pickup_request_id, waste_type_id])
}

model pickup_requests {
  pickup_request_id          Int                          @id @default(autoincrement())
  household_id               Int
  request_date               DateTime                     @db.Date
  status                     pickup_status?               @default(requested)
  requested_at               DateTime?                    @default(now()) @db.Timestamp(6)
  assigned_at                DateTime?                    @db.Timestamp(6)
  collected_at               DateTime?                    @db.Timestamp(6)
  cancelled_at               DateTime?                    @db.Timestamp(6)
  cancellation_reason        String?
  notes                      String?
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  deleted_at                 DateTime?                    @db.Timestamp(6)
  pickup_assignments         pickup_assignments[]
  pickup_request_waste_types pickup_request_waste_types[]
  households                 households                   @relation(fields: [household_id], references: [household_id], onDelete: NoAction, onUpdate: NoAction)
  violations                 violations[]

  @@index([household_id, status], map: "idx_pickup_household_status")
}

model violation_reasons {
  violation_reason_id Int          @id @default(autoincrement())
  reason_code         String       @unique @db.VarChar(20)
  reason_description  String       @db.VarChar(200)
  is_active           Boolean?     @default(true)
  created_at          DateTime?    @default(now()) @db.Timestamp(6)
  updated_at          DateTime?    @default(now()) @db.Timestamp(6)
  violations          violations[]
}

model violations {
  violation_id        Int               @id @default(autoincrement())
  household_id        Int
  worker_id           Int
  pickup_request_id   Int?
  violation_reason_id Int
  severity            severity_level?   @default(medium)
  violation_date      DateTime          @db.Date
  description         String?
  is_resolved         Boolean?          @default(false)
  created_at          DateTime?         @default(now()) @db.Timestamp(6)
  households          households        @relation(fields: [household_id], references: [household_id], onDelete: NoAction, onUpdate: NoAction)
  pickup_requests     pickup_requests?  @relation(fields: [pickup_request_id], references: [pickup_request_id], onDelete: NoAction, onUpdate: NoAction)
  violation_reasons   violation_reasons @relation(fields: [violation_reason_id], references: [violation_reason_id], onDelete: NoAction, onUpdate: NoAction)
  workers             workers           @relation(fields: [worker_id], references: [worker_id], onDelete: NoAction, onUpdate: NoAction)
}

model wards {
  ward_id       Int           @id @default(autoincrement())
  ward_name     String        @db.VarChar(100)
  ward_code     String        @unique @db.VarChar(20)
  description   String?
  is_active     Boolean?      @default(true)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  updated_at    DateTime?     @default(now()) @db.Timestamp(6)
  local_body_id Int?
  households    households[]
  local_bodies  local_bodies? @relation(fields: [local_body_id], references: [local_body_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ward_local_body")
  workers       workers[]
}

model waste_types {
  waste_type_id              Int                          @id @default(autoincrement())
  waste_type_name            String                       @unique @db.VarChar(50)
  description                String?
  is_recyclable              Boolean?                     @default(false)
  is_active                  Boolean?                     @default(true)
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  pickup_request_waste_types pickup_request_waste_types[]
}

model workers {
  worker_id          Int                  @id @default(autoincrement())
  ward_id            Int
  worker_name        String               @db.VarChar(200)
  phone              String               @unique @db.VarChar(20)
  email              String?              @db.VarChar(255)
  employee_id        String?              @unique @db.VarChar(50)
  is_active          Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  deleted_at         DateTime?            @db.Timestamp(6)
  pickup_assignments pickup_assignments[]
  violations         violations[]
  wards              wards                @relation(fields: [ward_id], references: [ward_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([is_active], map: "idx_workers_is_active")
  @@index([ward_id], map: "idx_workers_ward_id")
}

model districts {
  district_id   Int            @id @default(autoincrement())
  district_name String         @unique @db.VarChar(100)
  local_bodies  local_bodies[]
}

model local_bodies {
  local_body_id Int       @id @default(autoincrement())
  district_id   Int
  name          String    @db.VarChar(200)
  type          String    @db.VarChar(20)
  is_active     Boolean?  @default(true)
  districts     districts @relation(fields: [district_id], references: [district_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_local_body_district")
  wards         wards[]
}

enum admin_role {
  super_admin
  admin
  manager
}

enum pickup_status {
  requested
  assigned
  collected
  cancelled
}

enum severity_level {
  low
  medium
  high
}
